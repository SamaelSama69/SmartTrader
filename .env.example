# Free API Keys (Get from respective websites)

# News API - https://newsapi.org/register (100 requests/day free)
NEWS_API_KEY=your_news_api_key_here

# Reddit API - https://www.reddit.com/prefs/apps (create script app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=SmartTrader/1.0

# Finnhub - https://finnhub.io/register (60 calls/minute free)
FINNHUB_API_KEY=your_finnhub_api_key

# Optional: Alpha Vantage - https://www.alphavantage.co/support/#api-key (5 requests/min free)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# System Settings
LOG_LEVEL=INFO
CACHE_DAYS=30
MAX_TICKERS_TO_ANALYZE=10
