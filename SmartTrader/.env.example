# SmartTrader Environment Variables
# Copy this file to .env and fill in your API keys

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# News API (https://newsapi.org/)
# Free tier: 100 requests/day
NEWS_API_KEY=your_news_api_key_here

# Reddit API (https://www.reddit.com/prefs/apps/)
# Create a new app (script type) to get these credentials
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=SmartTrader/1.0

# Finnhub API (https://finnhub.io/)
# Free tier: 60 API calls/minute
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage API (https://www.alphavantage.co/)
# Free tier: 25 requests/day
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Zerodha Kite Connect API (https://kite.trade/)
# For Indian market trading (optional)
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here

# Trading Settings (optional - defaults are used if not set)
MAX_TICKERS_TO_ANALYZE=10
CACHE_DAYS=30

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace the placeholder values with your actual API keys
# 3. At minimum, get a News API key for basic functionality
# 4. For Indian markets, also configure Zerodha credentials
# 5. Keep your .env file secure and never commit it to version control
